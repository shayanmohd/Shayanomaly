# ══════════════════════════════════════════════════════════════
# Shayanomaly Frontend — Environment Variables
# Copy to .env.local and fill in values. All are optional:
# the app runs fully on public market-data APIs with none set.
# ══════════════════════════════════════════════════════════════

# WalletConnect project ID (https://cloud.walletconnect.com).
# Without it, injected wallets (MetaMask etc.) still work; QR-based
# mobile wallets are unavailable.
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# Self-hosted backend stream (full-stack mode). When set, the terminal
# consumes the backend arbitrage/anomaly feed instead of the in-browser
# engine. Leave unset for the static GitHub Pages build.
NEXT_PUBLIC_WS_URL=

# Base path when hosting under a sub-path (GitHub Pages project site).
# The deploy workflow sets this to /Shayanomaly automatically.
NEXT_PUBLIC_BASE_PATH=

# Canonical site URL used in metadata/sitemap.
NEXT_PUBLIC_SITE_URL=https://shayanmohd.github.io/Shayanomaly

# Set to "node" to produce the standalone server build (Docker).
BUILD_TARGET=
