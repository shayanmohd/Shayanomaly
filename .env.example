# ══════════════════════════════════════════════════════════════
# Shayanomaly Frontend — Environment Variables
# Copy to .env.local and fill in values
# ══════════════════════════════════════════════════════════════

# WalletConnect project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# Backend URLs (used by Next.js API proxy routes)
BACKEND_HTTP_URL=http://localhost:8081
BACKEND_WS_URL=ws://localhost:8080

# WebSocket URL (client-side, must be publicly reachable)
NEXT_PUBLIC_WS_URL=wss://yourdomain.com/ws

# Public domain (used for CORS, meta tags)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Node environment
NODE_ENV=production
