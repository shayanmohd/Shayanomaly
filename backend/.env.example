# ══════════════════════════════════════════════════════════════
# Shayanomaly Backend — Environment Variables
# Copy to .env and fill in values
# ══════════════════════════════════════════════════════════════

# Server ports
HTTP_PORT=8081
WS_PORT=8080

# Allowed origins (comma-separated, for CORS)
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# CEX API Keys (required for live execution)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# Ethereum Wallet (required for DEX/Flashbots execution)
ETH_PRIVATE_KEY=your_eth_private_key_here

# RPC endpoint (default: public llamarpc)
ETH_RPC_URL=https://eth.llamarpc.com

# Flash arbitrage contract address (deploy your own or leave default)
FLASH_ARB_ADDRESS=0x0000000000000000000000000000000000000000

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://user:password@db:5432/shayanomaly?schema=public"
